# Gemini API key — 강의자가 배포한 값을 붙여넣으세요.
GEMINI_API_KEY=your_gemini_key_here

# Langfuse — Day 1 trace 실습용.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Day 2 live LLM settings. Defaults are usually enough.
DAY2_LLM_MODE=live
DAY2_MODEL_CHEAP=gemini-2.5-flash-lite
DAY2_MODEL_STANDARD=gemini-2.5-flash
DAY2_MODEL_STRONG=gemini-2.5-pro
