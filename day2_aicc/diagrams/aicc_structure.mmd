flowchart LR
    A["app.py<br/>scenario -> AICCState"] --> G["graph.py<br/>node order only"]

    subgraph Host["Host Python nodes"]
        I["input_guard<br/>direct attack"] --> T["triage<br/>router, not agent"]
        T --> C["context<br/>load data + policy"]
        C --> CG["context_guard<br/>filter external payload"]
        AG["action_guard<br/>policy gate"] --> X["actions<br/>execute + final answer"]
    end

    subgraph Agent["LLM agent node"]
        S["specialist<br/>answer draft + proposed_actions"]
    end

    G --> I
    CG --> S --> AG
    X --> O["output<br/>answer, actions, risk_events"]

    C -. read .-> R["read tools<br/>order/customer/shipment/policy"]
    X -. write .-> W["write tools<br/>address/refund/coupon/ticket"]
    G -. thread_id .-> P[("checkpoint")]

    classDef host fill:#E8F1FF,stroke:#2563EB,color:#0F172A
    classDef agent fill:#FCE7F3,stroke:#DB2777,color:#0F172A
    classDef tool fill:#ECFDF5,stroke:#059669,color:#0F172A
    classDef io fill:#F8FAFC,stroke:#64748B,color:#0F172A

    class I,T,C,CG,AG,X host
    class S agent
